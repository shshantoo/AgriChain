<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AgriChain — Smart Farm Management System</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --green-dark: #1a3a2a;
    --green-mid: #2d6a4f;
    --green-light: #52b788;
    --green-pale: #b7e4c7;
    --amber: #f4a261;
    --amber-dark: #e76f51;
    --cream: #f8f5ef;
    --white: #ffffff;
    --text-dark: #1a1a1a;
    --text-muted: #6b7280;
    --card-bg: #ffffff;
    --border: #e5e7eb;
    --sidebar-w: 240px;
    --header-h: 64px;
    --radius: 14px;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
    --shadow-lg: 0 8px 40px rgba(0,0,0,0.13);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text-dark);
    min-height: 100vh;
  }

  h1,h2,h3,h4 { font-family: 'Syne', sans-serif; }

  /* ── ROLE SELECTOR SCREEN ── */
  #role-screen {
    min-height: 100vh;
    background: linear-gradient(135deg, #1a3a2a 0%, #2d6a4f 50%, #1a3a2a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }
  #role-screen .logo {
    font-family: 'Syne', sans-serif;
    font-size: 2.6rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -1px;
    margin-bottom: 6px;
  }
  #role-screen .logo span { color: var(--amber); }
  #role-screen .tagline {
    color: var(--green-pale);
    font-size: 1rem;
    margin-bottom: 50px;
    letter-spacing: 0.5px;
  }
  .role-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    max-width: 1000px;
    width: 100%;
  }
  .role-card {
    background: rgba(255,255,255,0.07);
    border: 1.5px solid rgba(255,255,255,0.15);
    border-radius: 20px;
    padding: 32px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(8px);
  }
  .role-card:hover {
    background: rgba(255,255,255,0.15);
    border-color: var(--amber);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.3);
  }
  .role-card .icon {
    font-size: 2.8rem;
    margin-bottom: 14px;
    display: block;
  }
  .role-card .role-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
  }
  .role-card .role-desc {
    font-size: 0.8rem;
    color: var(--green-pale);
    line-height: 1.5;
  }

  /* ── MAIN APP LAYOUT ── */
  #app { display: none; min-height: 100vh; }
  #app.active { display: flex; }

  /* SIDEBAR */
  .sidebar {
    width: var(--sidebar-w);
    min-height: 100vh;
    background: var(--green-dark);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0;
    z-index: 100;
    overflow-y: auto;
  }
  .sidebar-logo {
    padding: 22px 20px 16px;
    font-family: 'Syne', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    letter-spacing: -0.5px;
  }
  .sidebar-logo span { color: var(--amber); }
  .sidebar-role-badge {
    padding: 12px 20px;
    background: rgba(255,255,255,0.07);
    margin: 12px;
    border-radius: 10px;
    font-size: 0.78rem;
    color: var(--green-pale);
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .sidebar-role-badge strong {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 0.88rem;
    color: #fff;
    margin-bottom: 2px;
    text-transform: none;
    letter-spacing: 0;
  }
  .nav-section {
    padding: 8px 12px 4px;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-top: 8px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 11px 16px;
    margin: 2px 12px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
    transition: all 0.2s;
  }
  .nav-item:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .nav-item.active { background: var(--green-light); color: #fff; }
  .nav-item .nav-icon { font-size: 1.1rem; width: 22px; text-align: center; }
  .sidebar-bottom {
    margin-top: auto;
    padding: 16px;
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .switch-role-btn {
    width: 100%;
    padding: 10px;
    background: rgba(244,162,97,0.15);
    border: 1px solid rgba(244,162,97,0.3);
    border-radius: 10px;
    color: var(--amber);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }
  .switch-role-btn:hover { background: rgba(244,162,97,0.25); }

  /* MAIN CONTENT */
  .main-content {
    margin-left: var(--sidebar-w);
    flex: 1;
    min-height: 100vh;
  }
  .topbar {
    height: var(--header-h);
    background: var(--white);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .topbar-title { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 700; }
  .topbar-right { display: flex; align-items: center; gap: 16px; }
  .topbar-pill {
    background: #f0fdf4;
    color: var(--green-mid);
    border: 1px solid var(--green-pale);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .notif-btn {
    width: 36px; height: 36px;
    background: #f9fafb;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    position: relative;
  }
  .notif-dot {
    position: absolute; top: 4px; right: 4px;
    width: 8px; height: 8px;
    background: var(--amber-dark);
    border-radius: 50%;
    border: 2px solid #fff;
  }
  .avatar {
    width: 36px; height: 36px;
    background: var(--green-mid);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-family: 'Syne', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
  }

  .page-body { padding: 32px; display: none; }
  .page-body.active { display: block; }

  /* ── CARDS ── */
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
  }
  .stat-card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 22px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    transition: transform 0.2s;
  }
  .stat-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .stat-label { font-size: 0.78rem; color: var(--text-muted); font-weight: 500; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
  .stat-value { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; color: var(--text-dark); }
  .stat-sub { font-size: 0.78rem; color: var(--text-muted); margin-top: 4px; }
  .stat-badge { display: inline-block; margin-top: 8px; padding: 3px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
  .badge-green { background: #dcfce7; color: #16a34a; }
  .badge-amber { background: #fef3c7; color: #d97706; }
  .badge-red { background: #fee2e2; color: #dc2626; }
  .badge-blue { background: #dbeafe; color: #2563eb; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .section-header h3 { font-size: 1.1rem; font-weight: 700; }
  .btn {
    padding: 8px 18px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
  }
  .btn-primary { background: var(--green-mid); color: #fff; }
  .btn-primary:hover { background: var(--green-dark); }
  .btn-outline { background: transparent; border: 1.5px solid var(--border); color: var(--text-dark); }
  .btn-outline:hover { border-color: var(--green-mid); color: var(--green-mid); }
  .btn-amber { background: var(--amber); color: #fff; }
  .btn-amber:hover { background: var(--amber-dark); }
  .btn-sm { padding: 5px 12px; font-size: 0.78rem; }

  .card {
    background: var(--white);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    margin-bottom: 24px;
  }

  /* TABLE */
  table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  thead th {
    background: #f9fafb;
    padding: 11px 16px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid var(--border);
  }
  tbody td { padding: 13px 16px; border-bottom: 1px solid #f3f4f6; vertical-align: middle; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: #f9fafb; }

  /* PROGRESS BAR */
  .prog-bar { height: 8px; background: #f3f4f6; border-radius: 10px; overflow: hidden; margin-top: 6px; }
  .prog-fill { height: 100%; border-radius: 10px; background: var(--green-light); transition: width 0.6s ease; }
  .prog-fill.amber { background: var(--amber); }
  .prog-fill.red { background: var(--amber-dark); }

  /* GRID LAYOUTS */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .three-col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; }
  .two-thirds { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; }

  /* FORM */
  .form-group { margin-bottom: 18px; }
  .form-group label { display: block; font-size: 0.82rem; font-weight: 600; margin-bottom: 6px; color: var(--text-dark); }
  .form-control {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s;
    background: #fff;
  }
  .form-control:focus { border-color: var(--green-mid); }
  select.form-control { cursor: pointer; }

  /* ALERT */
  .alert {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 18px;
    border-radius: 10px;
    margin-bottom: 14px;
    font-size: 0.875rem;
  }
  .alert-warning { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }
  .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
  .alert-danger { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
  .alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1e40af; }

  /* TIMELINE */
  .timeline { position: relative; padding-left: 28px; }
  .timeline::before { content: ''; position: absolute; left: 8px; top: 0; bottom: 0; width: 2px; background: var(--border); }
  .tl-item { position: relative; margin-bottom: 22px; }
  .tl-dot {
    position: absolute; left: -24px; top: 2px;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--green-light);
    border: 2px solid #fff;
    box-shadow: 0 0 0 3px var(--green-pale);
  }
  .tl-dot.amber { background: var(--amber); box-shadow: 0 0 0 3px #fef3c7; }
  .tl-dot.red { background: var(--amber-dark); box-shadow: 0 0 0 3px #fee2e2; }
  .tl-title { font-weight: 600; font-size: 0.875rem; }
  .tl-meta { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }

  /* SENSOR GAUGE */
  .gauge-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 16px; }
  .gauge-card {
    background: #f9fafb;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 14px;
    text-align: center;
  }
  .gauge-icon { font-size: 1.8rem; margin-bottom: 8px; }
  .gauge-value { font-family: 'Syne', sans-serif; font-size: 1.5rem; font-weight: 800; }
  .gauge-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .gauge-status { margin-top: 8px; }

  /* QR CODE MOCK */
  .qr-mock {
    width: 100px; height: 100px;
    background: repeating-linear-gradient(0deg, #1a1a1a 0, #1a1a1a 8px, transparent 8px, transparent 16px),
                repeating-linear-gradient(90deg, #1a1a1a 0, #1a1a1a 8px, transparent 8px, transparent 16px);
    background-color: #fff;
    border: 3px solid #1a1a1a;
    border-radius: 6px;
  }

  /* MAP MOCK */
  .map-mock {
    height: 220px;
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 50%, #b1dfbb 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    font-size: 0.85rem;
    color: var(--green-dark);
    font-weight: 600;
  }
  .map-mock .pin {
    position: absolute;
    font-size: 1.5rem;
    animation: bounce 1.5s infinite;
  }
  @keyframes bounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  /* CHART MOCK */
  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 120px;
    padding: 0 4px;
  }
  .bar-chart .bar {
    flex: 1;
    background: linear-gradient(to top, var(--green-mid), var(--green-light));
    border-radius: 5px 5px 0 0;
    position: relative;
    transition: opacity 0.2s;
  }
  .bar-chart .bar:hover { opacity: 0.8; }
  .bar-chart .bar.amber { background: linear-gradient(to top, var(--amber-dark), var(--amber)); }
  .chart-labels { display: flex; gap: 8px; padding: 0 4px; margin-top: 6px; }
  .chart-labels span { flex: 1; text-align: center; font-size: 0.68rem; color: var(--text-muted); }

  /* DONUT MOCK */
  .donut-wrap { display: flex; align-items: center; gap: 20px; }
  .donut-svg { flex-shrink: 0; }
  .donut-legend { display: flex; flex-direction: column; gap: 8px; font-size: 0.8rem; }
  .donut-legend-item { display: flex; align-items: center; gap: 8px; }
  .donut-legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* NOTIFICATION PANEL */
  .notif-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px 0; border-bottom: 1px solid #f3f4f6; }
  .notif-item:last-child { border-bottom: none; }
  .notif-icon { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; flex-shrink: 0; }
  .notif-icon.green { background: #dcfce7; }
  .notif-icon.amber { background: #fef3c7; }
  .notif-icon.red { background: #fee2e2; }
  .notif-text { font-size: 0.85rem; font-weight: 500; }
  .notif-time { font-size: 0.75rem; color: var(--text-muted); margin-top: 2px; }

  /* PAGE HEADER */
  .page-header {
    margin-bottom: 28px;
  }
  .page-header h2 { font-size: 1.6rem; font-weight: 800; margin-bottom: 4px; }
  .page-header p { color: var(--text-muted); font-size: 0.9rem; }

  /* MOBILE FRAME MOCK */
  .mobile-frame {
    width: 280px;
    border: 8px solid #1a1a1a;
    border-radius: 36px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    background: #fff;
    margin: 0 auto;
  }
  .mobile-screen { padding: 20px 16px; }
  .mobile-header {
    background: var(--green-dark);
    color: #fff;
    padding: 16px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .two-col, .three-col, .two-thirds { grid-template-columns: 1fr; }
  }
  @media (max-width: 700px) {
    .sidebar { display: none; }
    .main-content { margin-left: 0; }
  }

  /* FADE ANIMATION */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .page-body.active { animation: fadeUp 0.3s ease; }

  /* ROLE SCREEN ANIMATION */
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  #role-screen { animation: fadeIn 0.5s ease; }
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════
     ROLE SELECTOR SCREEN
═══════════════════════════════════════════════════════════ -->
<div id="role-screen">
  <div class="logo">Agri<span>Chain</span></div>
  <div class="tagline">Smart Farm-to-Warehouse Management System</div>
  <div class="role-grid">
    <div class="role-card" onclick="enterRole('farmer')">
      <span class="icon">🌾</span>
      <div class="role-name">Farmer</div>
      <div class="role-desc">Sowing logs, harvest tracking, IoT sensor data & crop predictions</div>
    </div>
    <div class="role-card" onclick="enterRole('warehouse')">
      <span class="icon">🏭</span>
      <div class="role-name">Warehouse Manager</div>
      <div class="role-desc">Real-time inventory, stock visibility & incoming shipments</div>
    </div>
    <div class="role-card" onclick="enterRole('processing')">
      <span class="icon">⚙️</span>
      <div class="role-name">Processing Unit</div>
      <div class="role-desc">RFID auto-tracking, batch management & quality control</div>
    </div>
    <div class="role-card" onclick="enterRole('supplier')">
      <span class="icon">🚚</span>
      <div class="role-name">Supplier Portal</div>
      <div class="role-desc">Auto-orders, stock levels, delivery ETA & purchase orders</div>
    </div>
    <div class="role-card" onclick="enterRole('admin')">
      <span class="icon">📊</span>
      <div class="role-name">Admin / Analytics</div>
      <div class="role-desc">Predictive analytics, custom dashboards & system alerts</div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════
     MAIN APP
═══════════════════════════════════════════════════════════ -->
<div id="app">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">Agri<span>Chain</span></div>
    <div class="sidebar-role-badge">
      <strong id="sidebar-role-name">Farmer</strong>
      Logged in as <span id="sidebar-role-user">John Doe</span>
    </div>

    <!-- Nav items injected by JS -->
    <div id="sidebar-nav"></div>

    <div class="sidebar-bottom">
      <button class="switch-role-btn" onclick="switchRole()">⇄ Switch Role</button>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <div class="main-content">
    <div class="topbar">
      <div class="topbar-title" id="topbar-title">Dashboard</div>
      <div class="topbar-right">
        <div class="topbar-pill" id="topbar-pill">● System Online</div>
        <div class="notif-btn">🔔<div class="notif-dot"></div></div>
        <div class="avatar" id="topbar-avatar">JD</div>
      </div>
    </div>

    <!-- ── FARMER PAGES ── -->
    <div id="pages-farmer">
      <div class="page-body" id="farmer-dashboard">
        <div class="page-header">
          <h2>Farmer Dashboard</h2>
          <p>Overview of your farm, sensors and crop cycle — Season 2024/25</p>
        </div>
        <div class="alert alert-success">✅ <div><strong>IoT Sensors Active</strong> — All 12 field sensors are reporting normally. Last sync: 2 min ago.</div></div>
        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-label">Total Field Area</div>
            <div class="stat-value">48.5 <span style="font-size:1rem">ha</span></div>
            <div class="stat-sub">4 active plots</div>
            <span class="stat-badge badge-green">Healthy</span>
          </div>
          <div class="stat-card">
            <div class="stat-label">Crop Planted</div>
            <div class="stat-value">3</div>
            <div class="stat-sub">Paddy · Maize · Soybean</div>
            <span class="stat-badge badge-amber">In Progress</span>
          </div>
          <div class="stat-card">
            <div class="stat-label">Days to Harvest</div>
            <div class="stat-value">42</div>
            <div class="stat-sub">Paddy — Plot A1</div>
            <span class="stat-badge badge-blue">On Track</span>
          </div>
          <div class="stat-card">
            <div class="stat-label">Yield Prediction</div>
            <div class="stat-value">6.2 <span style="font-size:1rem">t</span></div>
