                <tr><td>Temp out of range</td><td>&gt; 25°C</td><td>SMS</td><td><span class="stat-badge badge-green">On</span></td></tr>
                <tr><td>Sensor offline</td><td>&gt; 10 min</td><td>Dashboard</td><td><span class="stat-badge badge-green">On</span></td></tr>
                <tr><td>Batch completion</td><td>100%</td><td>Email</td><td><span class="stat-badge badge-green">On</span></td></tr>
                <tr><td>Delivery delay</td><td>&gt; 2 hrs</td><td>Email + SMS</td><td><span class="stat-badge badge-amber">Off</span></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div><!-- end main-content -->
</div><!-- end app -->

<script>
const ROLES = {
  farmer: {
    name: 'Farmer',
    user: 'Ahmad Farid',
    avatar: 'AF',
    pill: '🌾 Farm: Plot A1',
    nav: [
      { section: 'Main' },
      { id: 'farmer-dashboard', icon: '🏠', label: 'Dashboard' },
      { section: 'Farm Activity' },
      { id: 'farmer-sowing', icon: '🌱', label: 'Sowing Log' },
      { id: 'farmer-harvest', icon: '🌾', label: 'Harvest Tracking' },
      { id: 'farmer-predictions', icon: '📈', label: 'Crop Predictions' },
    ],
    defaultPage: 'farmer-dashboard'
  },
  warehouse: {
    name: 'Warehouse Manager',
    user: 'Nurul Ain',
    avatar: 'NA',
    pill: '🏭 Warehouse: KL Central',
    nav: [
      { section: 'Main' },
      { id: 'warehouse-dashboard', icon: '🏠', label: 'Dashboard' },
      { section: 'Operations' },
      { id: 'warehouse-inventory', icon: '📦', label: 'Inventory' },
      { id: 'warehouse-analytics', icon: '📊', label: 'Analytics' },
    ],
    defaultPage: 'warehouse-dashboard'
  },
  processing: {
    name: 'Processing Unit',
    user: 'Razlan Ibrahim',
    avatar: 'RI',
    pill: '⚙️ Unit: Selangor Plant',
    nav: [
      { section: 'Main' },
      { id: 'processing-dashboard', icon: '🏠', label: 'Dashboard' },
      { section: 'Operations' },
      { id: 'processing-batches', icon: '🗂️', label: 'Batch Management' },
      { id: 'processing-qc', icon: '🔬', label: 'Quality Control' },
    ],
    defaultPage: 'processing-dashboard'
  },
  supplier: {
    name: 'Supplier Portal',
    user: 'Siti Mariam',
    avatar: 'SM',
    pill: '🚚 Supplier Access',
    nav: [
      { section: 'Main' },
      { id: 'supplier-dashboard', icon: '🏠', label: 'Dashboard' },
      { section: 'Procurement' },
      { id: 'supplier-orders', icon: '📋', label: 'Purchase Orders' },
      { id: 'supplier-stock', icon: '📉', label: 'Stock Monitor' },
    ],
    defaultPage: 'supplier-dashboard'
  },
  admin: {
    name: 'Admin / Analytics',
    user: 'Dr. Amirul',
    avatar: 'DA',
    pill: '🔧 Admin: All Regions',
    nav: [
      { section: 'Main' },
      { id: 'admin-dashboard', icon: '🏠', label: 'System Overview' },
      { section: 'Analytics' },
      { id: 'admin-analytics', icon: '📊', label: 'Predictive Analytics' },
      { id: 'admin-alerts', icon: '🔔', label: 'Alerts & Rules' },
      { section: 'Administration' },
      { id: 'admin-users', icon: '👥', label: 'User Management' },
    ],
    defaultPage: 'admin-dashboard'
  }
};

let currentRole = null;
let currentPage = null;

function enterRole(roleKey) {
  currentRole = roleKey;
  const role = ROLES[roleKey];

  document.getElementById('role-screen').style.display = 'none';
  const app = document.getElementById('app');
  app.style.display = 'flex';
  app.classList.add('active');

  // Sidebar
  document.getElementById('sidebar-role-name').textContent = role.name;
  document.getElementById('sidebar-role-user').textContent = role.user;
  document.getElementById('topbar-avatar').textContent = role.avatar;
  document.getElementById('topbar-pill').textContent = '● ' + role.pill;

  // Build nav
  const navEl = document.getElementById('sidebar-nav');
  navEl.innerHTML = '';
  role.nav.forEach(item => {
    if (item.section) {
      const s = document.createElement('div');
      s.className = 'nav-section';
      s.textContent = item.section;
      navEl.appendChild(s);
    } else {
      const n = document.createElement('div');
      n.className = 'nav-item';
      n.dataset.page = item.id;
      n.innerHTML = `<span class="nav-icon">${item.icon}</span>${item.label}`;
      n.onclick = () => navigateTo(item.id, item.label);
      navEl.appendChild(n);
    }
  });

  navigateTo(role.defaultPage, role.nav.find(n => n.id === role.defaultPage)?.label || 'Dashboard');
}

function navigateTo(pageId, label) {
  // Hide all pages
  document.querySelectorAll('.page-body').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

  // Show target page
  const page = document.getElementById(pageId);
  if (page) {
    page.classList.add('active');
    currentPage = pageId;
  }

  // Set active nav
  const navItem = document.querySelector(`.nav-item[data-page="${pageId}"]`);
  if (navItem) navItem.classList.add('active');

  document.getElementById('topbar-title').textContent = label || pageId;
}

function switchRole() {
  document.getElementById('app').style.display = 'none';
  document.getElementById('app').classList.remove('active');
  document.getElementById('role-screen').style.display = 'flex';
  currentRole = null;
}
</script>
</body>
</html>
